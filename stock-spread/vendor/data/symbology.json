      "kind": "bstocks",
      "suffix": "B",
      "pair": "{BASE}USDT",
      "settlement": "USDT",
      "enumerate": "GET /api/v3/exchangeInfo -> validate {UNDERLYING}BUSDT exists & status TRADING"
